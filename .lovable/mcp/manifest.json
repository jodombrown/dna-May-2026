{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "dna-platform-mcp",
      "version": "0.2.0",
      "title": "DNA (Diaspora Network of Africa)"
    },
    "tools": [
      {
        "name": "search_profiles",
        "title": "Search DNA member profiles",
        "description": "Search public DNA (Diaspora Network of Africa) member profiles by name, username, or headline. Returns basic public info and a shareable /dna/<username> profile link.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "description": "Name, username, or keyword to search for."
            },
            "limit": {
              "description": "Max results (default 10).",
              "type": "integer",
              "minimum": 1,
              "maximum": 25
            }
          },
          "required": [
            "query"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "get_profile",
        "title": "Get DNA profile by username",
        "description": "Fetch a single public DNA member profile by username (the /dna/<username> handle).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^@?[A-Za-z0-9._-]+$",
              "description": "The DNA username, without the leading @ or /dna/."
            }
          },
          "required": [
            "username"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_upcoming_events",
        "title": "List upcoming DNA events",
        "description": "List upcoming public events on the DNA platform (Convene module). Optionally filter by keyword.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Optional keyword filter (title/description).",
              "type": "string",
              "maxLength": 100
            },
            "limit": {
              "description": "Max results (default 10).",
              "type": "integer",
              "minimum": 1,
              "maximum": 25
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "list_communities",
        "title": "List DNA communities",
        "description": "List active public DNA communities (African diaspora affinity groups, chapters, and interest groups). Supports optional keyword search, category filter, and featured-only filter. Useful for agent discovery of relevant communities.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "query": {
              "description": "Optional keyword filter on community name/description/tags.",
              "type": "string",
              "maxLength": 100
            },
            "category": {
              "description": "Optional category filter.",
              "type": "string",
              "maxLength": 64
            },
            "featured_only": {
              "description": "If true, return only featured communities.",
              "type": "boolean"
            },
            "limit": {
              "description": "Max results (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
